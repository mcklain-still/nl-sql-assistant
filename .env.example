# --- For Railway deployment (provides all DB vars in one string) ---
DATABASE_URL=mysql://user:password@host:port/dbname

# --- For local development (fallback when DATABASE_URL is not set) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=shopbot_db
DB_PORT=3306

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key